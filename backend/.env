# EATSY Backend — Environment Variables
# Copy this file to .env and fill in your values

SECRET_KEY=your-very-secret-django-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_NAME=eatsy_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis (for Celery)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS — add your Ionic dev server
CORS_ORIGINS=http://localhost:4200,http://localhost:8100,capacitor://localhost
